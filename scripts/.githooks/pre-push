#!/usr/bin/env node
const { execSync } = require("node:child_process");

try {
	execSync("git fetch --quiet origin main", { stdio: "inherit", shell: process.platform === "win32" });
	execSync("node scripts/check-mergeability.js origin/main", { stdio: "inherit", shell: process.platform === "win32" });
} catch (error) {
	process.exit(1);
}
